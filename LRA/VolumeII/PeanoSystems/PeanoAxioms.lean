-- The Peano Axioms ‚Äî foundational primitives for Volume II.
-- No Mathlib. No imports.

namespace Peano

-- ============================================================
-- Primitive notions
-- ============================================================

/--
**[Axiom ‚Äî N : Type]**

The carrier set of the canonical Peano system.
Its elements are the positive integers.

*Sources:* Landau, *Foundations of Analysis*, ¬ß1 Axiom 1
*Notes cross-ref:* ¬ß1.1 ax:peano-system-existence
-/
axiom N : Type

/--
**[Axiom ‚Äî one : N]**

The distinguished initial element of the canonical Peano system.

*Sources:* Landau, *Foundations of Analysis*, ¬ß1 Axiom 1
*Notes cross-ref:* ¬ß1.1 ax:peano-system-existence
-/
axiom one : N

/--
**[Axiom ‚Äî successor : N ‚Üí N]**

The successor function.

*Sources:* Landau, *Foundations of Analysis*, ¬ß1 Axiom 2
*Notes cross-ref:* ¬ß1.1 def:peano-system
-/
axiom successor : N ‚Üí N

-- ============================================================
-- Peano axioms
-- ============================================================

/--
**[Axiom ‚Äî One Is Not a Successor]**

`successor x ‚âÝ one` for every `x : N`.

*Sources:* Landau ¬ß1 Axiom 3; Feferman A3; Mendelson P3
*Notes cross-ref:* ¬ß1.1 ax:peano-one-not-successor
-/
axiom ax_one_not_successor :
  ‚àÄ x : N, successor x ‚âÝ one

/--
**[Axiom ‚Äî Successor Is Injective]**

`successor x = successor y ‚Üí x = y` for all `x y : N`.

*Sources:* Landau ¬ß1 Axiom 4; Feferman A4; Mendelson P4
*Notes cross-ref:* ¬ß1.1 ax:peano-successor-injective
-/
axiom ax_successor_injective :
  ‚àÄ x y : N, successor x = successor y ‚Üí x = y

/--
**[Axiom ‚Äî Induction]**

If a property holds at `one` and is preserved by `successor`,
then it holds for every element of `N`.

*Sources:* Landau ¬ß1 Axiom 5; Feferman A5; Mendelson P5
*Notes cross-ref:* ¬ß1.1 ax:peano-induction
-/
axiom ax_induction :
  ‚àÄ (P : N ‚Üí Prop),
    P one ‚Üí
    (‚àÄ x : N, P x ‚Üí P (successor x)) ‚Üí
    ‚àÄ x : N, P x

/--
**[Theorem ‚Äî Induction Principle]**

A named wrapper around `ax_induction`.

*Dependencies:* `ax_induction`
*Notes cross-ref:* ¬ß1.1 thm:peano-induction-principle
-/
@[recursor 4]
theorem N_Induction {P : N ‚Üí Prop}
    (base : P one)
    (step : ‚àÄ n : N, P n ‚Üí P (successor n)) :
    ‚àÄ x : N, P x :=
  ax_induction P base step

-- ============================================================
-- Recursion / iterator machine
-- ============================================================

/--
**[Axiom ‚Äî Recursion Machine]**

For any type `T`, initial value `base : T`, and step rule
`step : T ‚Üí T`, `ax_recursion base step` is the function
`N ‚Üí T` generated by primitive recursion.

This is the Peano Iterator Theorem stated axiomatically.

*Sources:*
  Feferman, *The Number Systems*, ¬ß3.4 Theorem 3.4
  Mendelson, *Number Systems*, ¬ß2.2 Theorem 2.1
*Notes cross-ref:* ¬ß1.2 thm:peano-iterator
-/
axiom ax_recursion :
  ‚àÄ {T : Type}, T ‚Üí (T ‚Üí T) ‚Üí N ‚Üí T

/--
**[Axiom ‚Äî Recursion Base Clause]**

`ax_recursion base step one = base`.

*Dependencies:* `ax_recursion`, `one`
*Notes cross-ref:* ¬ß1.2 thm:iterator-base-clause
-/
axiom ax_recursion_one :
  ‚àÄ {T : Type} (base : T) (step : T ‚Üí T),
    ax_recursion base step one = base

/--
**[Axiom ‚Äî Recursion Successor Clause]**

`ax_recursion base step (successor n) =
 step (ax_recursion base step n)`.

*Dependencies:* `ax_recursion`, `successor`
*Notes cross-ref:* ¬ß1.2 thm:iterator-successor-clause
-/
axiom ax_recursion_successor :
  ‚àÄ {T : Type} (base : T) (step : T ‚Üí T) (n : N),
    ax_recursion base step (successor n) =
      step (ax_recursion base step n)

-- ============================================================
-- Public recursion names
-- ============================================================

noncomputable abbrev N_rec : ‚àÄ {T : Type}, T ‚Üí (T ‚Üí T) ‚Üí N ‚Üí T :=
  ax_recursion

theorem N_rec_one {T : Type} (base : T) (step : T ‚Üí T) :
    N_rec base step one = base :=
  ax_recursion_one base step

theorem N_rec_succ {T : Type} (base : T) (step : T ‚Üí T) (n : N) :
    N_rec base step (successor n) =
      step (N_rec base step n) :=
  ax_recursion_successor base step n

end Peano
